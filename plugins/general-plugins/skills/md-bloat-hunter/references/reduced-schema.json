{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "md-bloat-hunter reduced file-orchestrator output",
  "type": "object",
  "additionalProperties": false,
  "required": ["file_path", "detector_status", "findings"],
  "properties": {
    "file_path": {
      "type": "string",
      "minLength": 1
    },
    "detector_status": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "required": ["specialist"],
            "properties": {
              "specialist": { "const": "redundancy-detector" }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["specialist"],
            "properties": {
              "specialist": { "const": "verbosity-pruner" }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["specialist"],
            "properties": {
              "specialist": { "const": "filler-eliminator" }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "required": ["specialist"],
            "properties": {
              "specialist": { "const": "vocab-compressor" }
            }
          },
          "minContains": 1,
          "maxContains": 1
        }
      ],
      "items": {
        "$ref": "#/$defs/detectorStatus"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reducedFinding"
      }
    }
  },
  "$defs": {
    "detectorStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specialist", "status", "output_path", "findings_included", "notes"],
      "properties": {
        "specialist": {
          "$ref": "#/$defs/specialist"
        },
        "status": {
          "type": "string",
          "enum": ["included", "partial", "skipped"]
        },
        "output_path": {
          "type": ["string", "null"]
        },
        "findings_included": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "reducedFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolution",
        "recommendation",
        "source_specialists",
        "source_order",
        "recommended_alternative_index",
        "excerpt",
        "context_before",
        "context_after",
        "type",
        "rationale",
        "severity",
        "action",
        "new_text",
        "justification",
        "semantic_risk",
        "confidence",
        "alternatives",
        "resolution_notes"
      ],
      "allOf": [
        { "$ref": "#/$defs/editConsistency" },
        { "$ref": "#/$defs/reducedSourceContract" },
        {
          "if": {
            "properties": { "resolution": { "enum": ["single", "merged"] } },
            "required": ["resolution"]
          },
          "then": {
            "properties": {
              "alternatives": {
                "maxItems": 0
              },
              "recommended_alternative_index": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "resolution": { "enum": ["alternatives", "conflict"] } },
            "required": ["resolution"]
          },
          "then": {
            "properties": {
              "alternatives": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": { "recommendation": { "const": "apply-recommended" } },
            "required": ["recommendation"]
          },
          "then": {
            "properties": {
              "recommended_alternative_index": {
                "type": "integer",
                "minimum": 0
              },
              "alternatives": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": { "recommendation": { "const": "apply" } },
            "required": ["recommendation"]
          },
          "then": {
            "properties": {
              "resolution": {
                "enum": ["single", "merged"]
              }
            }
          }
        }
      ],
      "properties": {
        "resolution": {
          "type": "string",
          "enum": ["single", "merged", "alternatives", "conflict"]
        },
        "recommendation": {
          "type": "string",
          "enum": ["apply", "apply-recommended", "ask-user", "skip"]
        },
        "source_specialists": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/specialist"
          }
        },
        "source_order": {
          "type": "integer",
          "minimum": 0
        },
        "recommended_alternative_index": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "excerpt": {
          "type": "string",
          "minLength": 1
        },
        "context_before": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "context_after": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "type": {
          "$ref": "#/$defs/findingType"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "action": {
          "$ref": "#/$defs/action"
        },
        "new_text": {
          "type": ["string", "null"]
        },
        "justification": {
          "type": ["string", "null"]
        },
        "semantic_risk": {
          "$ref": "#/$defs/semanticRisk"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "alternatives": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/alternativeFinding"
          }
        },
        "resolution_notes": {
          "type": "string"
        }
      }
    },
    "alternativeFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_specialist",
        "source_index",
        "source_order",
        "excerpt",
        "context_before",
        "context_after",
        "type",
        "rationale",
        "severity",
        "action",
        "new_text",
        "justification",
        "semantic_risk",
        "confidence"
      ],
      "allOf": [
        { "$ref": "#/$defs/editConsistency" },
        { "$ref": "#/$defs/alternativeSourceContract" }
      ],
      "properties": {
        "source_specialist": {
          "$ref": "#/$defs/specialist"
        },
        "source_index": {
          "type": "integer",
          "minimum": 0
        },
        "source_order": {
          "type": "integer",
          "minimum": 0
        },
        "excerpt": {
          "type": "string",
          "minLength": 1
        },
        "context_before": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "context_after": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "type": {
          "$ref": "#/$defs/findingType"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "action": {
          "$ref": "#/$defs/action"
        },
        "new_text": {
          "type": ["string", "null"]
        },
        "justification": {
          "type": ["string", "null"]
        },
        "semantic_risk": {
          "$ref": "#/$defs/semanticRisk"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "editConsistency": {
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "vocab" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "justification": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "filler" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "action": {
                "const": "delete"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "verbosity" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "action": {
                "enum": ["replace", "restructure"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "vocab" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "action": {
                "enum": ["replace", "restructure"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "action": { "const": "delete" } },
            "required": ["action"]
          },
          "then": {
            "properties": {
              "new_text": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "new_text": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "reducedSourceContract": {
      "allOf": [
        {
          "if": {
            "properties": {
              "source_specialists": {
                "maxItems": 1,
                "contains": { "const": "redundancy-detector" }
              }
            },
            "required": ["source_specialists"]
          },
          "then": {
            "properties": {
              "type": { "const": "redundancy" },
              "action": { "enum": ["delete", "replace", "restructure"] }
            }
          }
        },
        {
          "if": {
            "properties": {
              "source_specialists": {
                "maxItems": 1,
                "contains": { "const": "verbosity-pruner" }
              }
            },
            "required": ["source_specialists"]
          },
          "then": {
            "properties": {
              "type": { "const": "verbosity" },
              "action": { "enum": ["replace", "restructure"] }
            }
          }
        },
        {
          "if": {
            "properties": {
              "source_specialists": {
                "maxItems": 1,
                "contains": { "const": "filler-eliminator" }
              }
            },
            "required": ["source_specialists"]
          },
          "then": {
            "properties": {
              "type": { "const": "filler" },
              "action": { "const": "delete" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "source_specialists": {
                "maxItems": 1,
                "contains": { "const": "vocab-compressor" }
              }
            },
            "required": ["source_specialists"]
          },
          "then": {
            "properties": {
              "type": { "const": "vocab" },
              "action": { "enum": ["replace", "restructure"] }
            }
          }
        }
      ]
    },
    "alternativeSourceContract": {
      "allOf": [
        {
          "if": {
            "properties": { "source_specialist": { "const": "redundancy-detector" } },
            "required": ["source_specialist"]
          },
          "then": {
            "properties": {
              "type": { "const": "redundancy" },
              "action": { "enum": ["delete", "replace", "restructure"] }
            }
          }
        },
        {
          "if": {
            "properties": { "source_specialist": { "const": "verbosity-pruner" } },
            "required": ["source_specialist"]
          },
          "then": {
            "properties": {
              "type": { "const": "verbosity" },
              "action": { "enum": ["replace", "restructure"] }
            }
          }
        },
        {
          "if": {
            "properties": { "source_specialist": { "const": "filler-eliminator" } },
            "required": ["source_specialist"]
          },
          "then": {
            "properties": {
              "type": { "const": "filler" },
              "action": { "const": "delete" }
            }
          }
        },
        {
          "if": {
            "properties": { "source_specialist": { "const": "vocab-compressor" } },
            "required": ["source_specialist"]
          },
          "then": {
            "properties": {
              "type": { "const": "vocab" },
              "action": { "enum": ["replace", "restructure"] }
            }
          }
        }
      ]
    },
    "specialist": {
      "type": "string",
      "enum": [
        "redundancy-detector",
        "verbosity-pruner",
        "filler-eliminator",
        "vocab-compressor"
      ]
    },
    "findingType": {
      "type": "string",
      "enum": ["redundancy", "verbosity", "filler", "vocab"]
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "major", "minor"]
    },
    "action": {
      "type": "string",
      "enum": ["delete", "replace", "restructure"]
    },
    "semanticRisk": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    }
  }
}
